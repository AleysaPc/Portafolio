---
import "../../styles/global.css";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Demo Sistema</title>
  </head>

  <body class="min-h-screen bg-gray-50 flex">
    <!-- SIDEBAR -->
    <aside class="w-64 bg-white shadow flex flex-col">
      <!-- Header -->
      <div class="p-4 px-6 flex items-center gap-2 bg-red-500">
        <span class="text-white text-xl">👑</span>
        <h1 class="text-white text-xl font-bold">Conquistador</h1>
      </div>

      <!-- Perfil -->
      <div
        class="px-4 py-6 border-b flex flex-col items-center text-center bg-orange-500"
      >
        <div
          class="w-16 h-16 rounded-full bg-blue-500 flex items-center justify-center text-white font-semibold text-xl mb-3"
        >
          UD
        </div>

        <p class="text-sm font-medium text-white">Usuario Demo</p>
        <p class="text-xs text-white">demo@sistema.com</p>
      </div>

      <!-- Menú -->
      <div class="flex-1 overflow-y-auto px-2 py-4 space-y-2">
        <div class="px-4 py-3 rounded-lg bg-gray-700 text-white font-semibold">
          Dashboard
        </div>

        <div class="px-4 py-3 rounded-lg hover:bg-gray-200 text-gray-700">
          Ventas
        </div>

        <div class="px-4 py-3 rounded-lg hover:bg-gray-200 text-gray-700">
          Clientes
        </div>

        <div class="px-4 py-3 rounded-lg hover:bg-gray-200 text-gray-700">
          Inventario
        </div>
      </div>
    </aside>

    <!-- CONTENIDO -->
    <div class="flex-1 flex flex-col h-screen">
      <!-- NAVBAR -->
      <header
        class="flex justify-between items-center p-4 text-white bg-gray-500 shadow-md"
      >
        <!-- Botón -->
        <div class="text-xl">☰</div>

        <div class="text-sm">Inicio</div>

        <!-- Notificaciones -->
        <div class="flex items-center gap-4">
          <div class="relative">
            🔔
            <span
              class="absolute -top-1 -right-2 bg-red-500 text-xs px-1 rounded-full"
            >
              2
            </span>
          </div>

          <!-- Usuario -->
          <div class="text-sm">⋮</div>
        </div>
      </header>

      <!-- MAIN -->
      <main class="flex-1 overflow-y-auto bg-gray-100 p-6">
        <div class="max-w-7xl mx-auto space-y-6">
          <!-- CARDS -->
          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white p-5 rounded shadow">
              <p class="text-gray-500">Ventas hoy</p>
              <p class="text-xl font-bold">$1,250</p>
            </div>

            <div class="bg-white p-5 rounded shadow">
              <p class="text-gray-500">Clientes</p>
              <p class="text-xl font-bold">32</p>
            </div>

            <div class="bg-white p-5 rounded shadow">
              <p class="text-gray-500">Productos</p>
              <p class="text-xl font-bold">120</p>
            </div>
          </div>

          <!-- TABLA -->
          <div class="bg-white p-5 rounded shadow">
            <h2 class="mb-4 font-semibold">Últimas ventas</h2>

            <table class="w-full text-left text-sm">
              <thead class="text-gray-400">
                <tr>
                  <th class="pb-2">Cliente</th>
                  <th class="pb-2">Producto</th>
                  <th class="pb-2">Total</th>
                </tr>
              </thead>

              <tbody class="text-gray-700">
                <tr class="border-t">
                  <td class="py-2">Juan Pérez</td>
                  <td>Producto A</td>
                  <td>$120</td>
                </tr>

                <tr class="border-t">
                  <td class="py-2">Ana López</td>
                  <td>Producto B</td>
                  <td>$80</td>
                </tr>

                <tr class="border-t">
                  <td class="py-2">Carlos Ruiz</td>
                  <td>Producto C</td>
                  <td>$200</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
